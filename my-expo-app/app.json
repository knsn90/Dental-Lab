{
  "expo": {
    "name": "Dental Lab",
    "slug": "dental-lab-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dental-lab",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dentallab.app",
      "infoPlist": {
        "NSCameraUsageDescription": "İş emri fotoğrafı çekmek ve QR okutmak için kamera erişimi gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Fotoğraf galerinize erişmek için izin gerekiyor.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A56DB"
      },
      "package": "com.dentallab.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fotoğraf galerinize erişmek için izin gerekiyor.",
          "cameraPermission": "Kamera ile fotoğraf çekmek için izin gerekiyor."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QR kod okutmak ve iş emri fotoğrafı çekmek için kamera gerekiyor."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A56DB"
        }
      ],
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
