<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dentallab.expo</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/Users/saber/Desktop/Dental Software/my-expo-app/node_modules/.bin/expo</string>
    <string>start</string>
    <string>--web</string>
    <string>--port</string>
    <string>8081</string>
    <string>--non-interactive</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/saber/Desktop/Dental Software/my-expo-app</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
